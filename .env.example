# Local LLM (hackathon-compliant default)
LOCAL_LLM_PROVIDER=ollama
LOCAL_LLM_MODEL=llama3.1:8b
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_TEMPERATURE=0.0
LOCAL_LLM_MAX_WORKERS=2

